          </a>
        </li>
      </ul>
      <div class="contact-actions">
        <a href="https://badteddy.carrd.co" target="_blank" rel="noreferrer noopener" class="button button-primary">SEE MORE</a>
      </div>
    </section>
  </div>
</Layout>
