    <section class="section-card contact-card">
      <p class="eyebrow">Contact</p>
      <h2>Let’s build something extraordinary.</h2>
      <ul class="contact-list">
        <li>
          <a href="mailto:phisherman400@gmail.com">
            <Icon.Mail size={18} />
            <span>phisherman400@gmail.com</span>
          </a>
        </li>
        <li>
          <a href="https://github.com/badteddy1" target="_blank" rel="noreferrer noopener">
            <Icon.GitBranch size={18} />
            <span>github.com/badteddy1</span>
          </a>
        </li>
        <li>
          <a href="https://linkedin.com/in/sunday-owoicho-844495418" target="_blank" rel="noreferrer noopener">
            <Icon.Link size={18} />
            <span>linkedin.com/in/sunday-owoicho-844495418</span>
          </a>
        </li>
        <li>
          <a href="https://wa.me/2348123680686" target="_blank" rel="noreferrer noopener">
            <Icon.MessageCircle size={18} />
            <span>WhatsApp +234 812 368 0686</span>
          </a>
        </li>
        <li>
